{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug HoraMarcada API",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/backend/cmd/api",
      "cwd": "${workspaceFolder}/backend",
      "showLog": true
    },
    {
      "name": "Debug HoraMarcada API (PORT 8081)",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/backend/cmd/api",
      "cwd": "${workspaceFolder}/backend",
      "showLog": true,
      "env": {
        "PORT": "8081"
      }
    }
  ]
}
